{
  "info": {
    "name": "CDC Demo - Postgres Debezium Redis",
    "description": "Spring Boot REST API demonstrating CDC (Change Data Capture) with Debezium. Writes go to PostgreSQL, Debezium streams WAL changes to Redis, reads are served from Redis.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. User Write API (PostgreSQL)",
      "description": "CRUD operations writing users to PostgreSQL. Changes are captured by Debezium CDC and streamed to Redis.",
      "item": [
        {
          "name": "1.1 Create User - alice (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice@example.com\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Creates a new user in PostgreSQL. Debezium CDC will stream this to Redis as user:{id}."
          }
        },
        {
          "name": "1.2 Create User - bob (USER)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"bob\",\n  \"email\": \"bob@example.com\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Creates a second user in PostgreSQL."
          }
        },
        {
          "name": "1.3 Create User - charlie (MANAGER)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"charlie\",\n  \"email\": \"charlie@example.com\",\n  \"role\": \"MANAGER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Creates a third user in PostgreSQL."
          }
        },
        {
          "name": "1.4 Update User - alice to SUPERADMIN",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice@example.com\",\n  \"role\": \"SUPERADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Updates alice's role. Debezium CDC will propagate the UPDATE to Redis."
          }
        },
        {
          "name": "1.5 Delete User - charlie",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/users/3",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "3"]
            },
            "description": "Deletes charlie from PostgreSQL. Debezium CDC will remove user:3 from Redis."
          }
        }
      ]
    },
    {
      "name": "2. Order Write API (PostgreSQL)",
      "description": "CRUD operations writing orders to PostgreSQL. Changes are captured by Debezium CDC and streamed to Redis.",
      "item": [
        {
          "name": "2.1 Create Order - alice's Laptop (PENDING)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"amount\": 299.99,\n  \"description\": \"Laptop\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            },
            "description": "Creates an order with default status PENDING. CDC streams to Redis as order:{id}."
          }
        },
        {
          "name": "2.2 Create Order - alice's Mouse (CONFIRMED)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"amount\": 49.99,\n  \"status\": \"CONFIRMED\",\n  \"description\": \"Mouse\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            },
            "description": "Creates an order with explicit CONFIRMED status."
          }
        },
        {
          "name": "2.3 Create Order - bob's Monitor",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 2,\n  \"amount\": 999.00,\n  \"description\": \"Monitor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            },
            "description": "Creates an order for bob."
          }
        },
        {
          "name": "2.4 Update Order - full update",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"amount\": 349.99,\n  \"status\": \"CONFIRMED\",\n  \"description\": \"Laptop (upgraded)\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "1"]
            },
            "description": "Full update of order 1. CDC propagates the change to Redis."
          }
        },
        {
          "name": "2.5 Update Order Status - SHIPPED",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"SHIPPED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/1/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "1", "status"]
            },
            "description": "Updates only the status field. CDC propagates the change to Redis."
          }
        },
        {
          "name": "2.6 Update Order Status - DELIVERED",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DELIVERED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/1/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "1", "status"]
            },
            "description": "Updates order status to DELIVERED."
          }
        },
        {
          "name": "2.7 Delete Order",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/orders/3",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "3"]
            },
            "description": "Deletes order 3. CDC removes order:3 from Redis."
          }
        }
      ]
    },
    {
      "name": "3. User Read API (Redis)",
      "description": "Read operations served from Redis (CDC-populated cache). Data arrives here via Debezium CDC pipeline.",
      "item": [
        {
          "name": "3.1 Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Lists all users from Redis. Uses KEYS + MGET to fetch all user:* keys."
          }
        },
        {
          "name": "3.2 Get User by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Gets a single user from Redis by ID. Returns 404 if key not in Redis."
          }
        },
        {
          "name": "3.3 Get User by ID (not found)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "999"]
            },
            "description": "Tests 404 response when user key doesn't exist in Redis."
          }
        }
      ]
    },
    {
      "name": "4. Order Read API (Redis)",
      "description": "Read operations served from Redis (CDC-populated cache).",
      "item": [
        {
          "name": "4.1 Get All Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            },
            "description": "Lists all orders from Redis."
          }
        },
        {
          "name": "4.2 Get Order by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "1"]
            },
            "description": "Gets a single order from Redis by ID."
          }
        },
        {
          "name": "4.3 Get Orders by User ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders/user/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "user", "1"]
            },
            "description": "Gets all orders for a specific user from Redis. Fetches all orders and filters by userId."
          }
        },
        {
          "name": "4.4 Get Order by ID (not found)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders/999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "999"]
            },
            "description": "Tests 404 response when order key doesn't exist in Redis."
          }
        }
      ]
    },
    {
      "name": "5. Health & Observability",
      "description": "Health check and observability endpoints.",
      "item": [
        {
          "name": "5.1 CDC Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/health/cdc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health", "cdc"]
            },
            "description": "CDC pipeline health — shows CDC mode and Redis connectivity status."
          }
        },
        {
          "name": "5.2 Actuator Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "health"]
            },
            "description": "Spring Boot health check — shows PostgreSQL, Redis, and disk status."
          }
        },
        {
          "name": "5.3 Actuator Info",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/actuator/info",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "info"]
            },
            "description": "Application info endpoint."
          }
        },
        {
          "name": "5.4 Actuator Metrics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/actuator/metrics",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "metrics"]
            },
            "description": "Available metrics list."
          }
        }
      ]
    },
    {
      "name": "6. CDC End-to-End Flow",
      "description": "Step-by-step requests to demonstrate the full CDC pipeline: Write to PostgreSQL → Debezium reads WAL → Redis populated → Read from Redis.",
      "item": [
        {
          "name": "Step 1: Create user (Write API → PostgreSQL)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo_user\",\n  \"email\": \"demo@example.com\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Step 1: Write user to PostgreSQL. Note the returned ID."
          }
        },
        {
          "name": "Step 2: Read user from Redis (Read API)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Step 2: Read user from Redis. If 404, wait 1-2 seconds for CDC pipeline to propagate, then retry."
          }
        },
        {
          "name": "Step 3: Update user (Write API → PostgreSQL)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo_user\",\n  \"email\": \"demo_updated@example.com\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Step 3: Update user in PostgreSQL. CDC will propagate the change to Redis."
          }
        },
        {
          "name": "Step 4: Verify update in Redis (Read API)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Step 4: Verify the updated role and email appear in Redis."
          }
        },
        {
          "name": "Step 5: Delete user (Write API → PostgreSQL)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Step 5: Delete user from PostgreSQL. CDC will remove the key from Redis."
          }
        },
        {
          "name": "Step 6: Verify deletion in Redis (Read API - expect 404)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Step 6: Verify user:1 key is gone from Redis. Should return 404."
          }
        }
      ]
    },
    {
      "name": "7. Validation Error Cases",
      "description": "Requests that trigger validation errors to verify error handling.",
      "item": [
        {
          "name": "7.1 Create User - missing username",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Should return 400 with validation error: username is required."
          }
        },
        {
          "name": "7.2 Create User - invalid email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"test\",\n  \"email\": \"not-an-email\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Should return 400 with validation error: email must be valid."
          }
        },
        {
          "name": "7.3 Create Order - missing amount",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"description\": \"Test\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            },
            "description": "Should return 400 with validation error: amount is required."
          }
        },
        {
          "name": "7.4 Create Order - zero amount",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"amount\": 0,\n  \"description\": \"Test\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            },
            "description": "Should return 400: amount must be greater than 0."
          }
        },
        {
          "name": "7.5 Update non-existent user",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ghost\",\n  \"email\": \"ghost@example.com\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "999"]
            },
            "description": "Should return 404: User with id 999 not found."
          }
        },
        {
          "name": "7.6 Malformed JSON body",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ invalid json }"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Should return 400: Invalid request body format."
          }
        }
      ]
    }
  ]
}
